# Anthropic API key for label image analysis.
# Get one at https://console.anthropic.com → API Keys.
# Without it, the app runs in demo mode (canned results for the bundled samples).
ANTHROPIC_API_KEY=

# Optional: override the vision model. Defaults to claude-haiku-4-5 (fastest,
# comfortably meets the ~5 second target). claude-sonnet-5 trades speed for
# accuracy headroom on very difficult photos.
# CLAUDE_MODEL=claude-haiku-4-5
